{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dot-ai.dev/schemas/decision-0.1.0.schema.json",
  "title": ".ai Decision Metadata",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "date"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "superseded",
        "rejected"
      ]
    },
    "date": {
      "type": "string"
    },
    "affectedSpecs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
