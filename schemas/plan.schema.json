{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dot-ai.dev/schemas/plan-0.1.0.schema.json",
  "title": ".ai Plan Metadata",
  "type": "object",
  "required": [
    "title",
    "status",
    "sourceSpec",
    "created",
    "updated"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "in-progress",
        "completed",
        "superseded"
      ]
    },
    "sourceSpec": {
      "type": "string"
    },
    "created": {
      "type": "string"
    },
    "updated": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
